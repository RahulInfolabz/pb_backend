{
  "info": {
    "name": "PG and Co-Living Accommodation Finder Platform",
    "description": "Complete API collection for PG and Co-Living Accommodation Finder Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Common",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/signup",
              "host": ["{{base_url}}"],
              "path": ["signup"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Arjun Mehta\",\n  \"email\": \"arjun@gmail.com\",\n  \"password\": \"Arjun@123\",\n  \"mobile_no\": \"9900000002\",\n  \"city\": \"Ahmedabad\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"arjun@gmail.com\",\n  \"password\": \"Arjun@123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/logout",
              "host": ["{{base_url}}"],
              "path": ["logout"]
            }
          }
        },
        {
          "name": "Session",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/session",
              "host": ["{{base_url}}"],
              "path": ["session"]
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/changePassword",
              "host": ["{{base_url}}"],
              "path": ["changePassword"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"arjun@gmail.com\",\n  \"newPassword\": \"NewPass@123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "🌐 Public",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/categories",
              "host": ["{{base_url}}"],
              "path": ["categories"]
            }
          }
        },
        {
          "name": "Get All Accommodation Types",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/accommodationTypes",
              "host": ["{{base_url}}"],
              "path": ["accommodationTypes"]
            }
          }
        },
        {
          "name": "Get All PG Listings",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/pglistings",
              "host": ["{{base_url}}"],
              "path": ["pglistings"]
            }
          }
        },
        {
          "name": "Get PG Listings — Filter by Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/pglistings?category_id=CATEGORY_ID_HERE",
              "host": ["{{base_url}}"],
              "path": ["pglistings"],
              "query": [{ "key": "category_id", "value": "CATEGORY_ID_HERE" }]
            }
          }
        },
        {
          "name": "Get PG Listings — Filter by Accommodation Type",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/pglistings?accommodation_type_id=TYPE_ID_HERE",
              "host": ["{{base_url}}"],
              "path": ["pglistings"],
              "query": [{ "key": "accommodation_type_id", "value": "TYPE_ID_HERE" }]
            }
          }
        },
        {
          "name": "Get PG Listings — Filter by Rent Range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/pglistings?min_rent=4000&max_rent=8000",
              "host": ["{{base_url}}"],
              "path": ["pglistings"],
              "query": [
                { "key": "min_rent", "value": "4000" },
                { "key": "max_rent", "value": "8000" }
              ]
            }
          }
        },
        {
          "name": "Get PG Details",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/pglistings/PG_ID_HERE",
              "host": ["{{base_url}}"],
              "path": ["pglistings", "PG_ID_HERE"]
            }
          }
        },
        {
          "name": "Get All Feedbacks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/feedbacks",
              "host": ["{{base_url}}"],
              "path": ["feedbacks"]
            }
          }
        }
      ]
    },
    {
      "name": "🟢 User (Session Required)",
      "item": [
        {
          "name": "Update Profile",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/user/updateProfile",
              "host": ["{{base_url}}"],
              "path": ["user", "updateProfile"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Arjun Kumar Mehta\",\n  \"mobile_no\": \"9911111111\",\n  \"city\": \"Gandhinagar\",\n  \"profile_image\": \"https://i.pravatar.cc/150?img=10\"\n}"
            }
          }
        },
        {
          "name": "Add PG Inquiry",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/user/addPGInquiry",
              "host": ["{{base_url}}"],
              "path": ["user", "addPGInquiry"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pg_id\": \"PG_ID_HERE\",\n  \"inquiry_message\": \"Is this PG available from next month? I need a single room with AC.\"\n}"
            }
          }
        },
        {
          "name": "My PG Inquiries",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/user/myPGInquiries",
              "host": ["{{base_url}}"],
              "path": ["user", "myPGInquiries"]
            }
          }
        },
        {
          "name": "Add General Inquiry",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/user/addGeneralInquiry",
              "host": ["{{base_url}}"],
              "path": ["user", "addGeneralInquiry"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inquiry_subject\": \"PG near PDPU University\",\n  \"inquiry_message\": \"I am looking for a boys PG near PDPU University, Gandhinagar. Do you have any listings in that area?\"\n}"
            }
          }
        },
        {
          "name": "My General Inquiries",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/user/myGeneralInquiries",
              "host": ["{{base_url}}"],
              "path": ["user", "myGeneralInquiries"]
            }
          }
        },
        {
          "name": "Add Feedback",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/user/addFeedback",
              "host": ["{{base_url}}"],
              "path": ["user", "addFeedback"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"feedback_message\": \"Great platform! Found my PG within minutes. Very easy to use.\",\n  \"rating\": 5\n}"
            }
          }
        }
      ]
    }
  ]
}
